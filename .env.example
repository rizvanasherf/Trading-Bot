# ── Angel One SmartAPI Credentials ──
# Setup developer keys at the Angel One SmartAPI portal:
# https://smartapi.angelbroking.com
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PIN=your_4_digit_pin_here
ANGEL_TOTP_SECRET=your_totp_secret_key_here

# ── Telegram Notifications (Optional) ──
# Setup a bot via @BotFather to receive notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Trading Mode ──
# Mode: "paper" (virtual trading) or "live" (sends real MIS orders to Zerodha)
TRADING_MODE=paper
